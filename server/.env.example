# MongoDB 数据库地址
MONGO_URI=mongodb://localhost:27017/mirrornovel

# JWT 密钥（任意随机字符串）
JWT_SECRET=your_random_jwt_secret_here

# Token 过期时间
JWT_EXPIRES_IN=7d

# 管理员账号（启动时自动创建）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
ADMIN_NICKNAME=管理员

# 端口（可选，默认 3001）
# PORT=3001

# 邮箱配置（用于发送验证码，可选）
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
EMAIL_FROM=MirrorNovel <noreply@example.com>
